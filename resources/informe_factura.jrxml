				<imageExpression><![CDATA[$P{P_LOGO}]]></imageExpression>
			</image>
		</band>
	</title>
	<pageHeader>
		<band height="35" splitType="Stretch">
			<staticText>
				<reportElement x="175" y="0" width="201" height="20" uuid="6dd2e30f-044a-4f1c-bc89-7bf61e923af5"/>
				<text><![CDATA[FACTURA ÚLTIMO PAGO POR CLIENTE]]></text>
			</staticText>
		</band>
	</pageHeader>
	<columnHeader>
		<band height="41" splitType="Stretch">
			<textField>
				<reportElement x="0" y="0" width="144" height="20" uuid="9ee89155-a383-4a29-ae76-30138975262c"/>
				<textFieldExpression><![CDATA["DNI/NIE: " + $F{DNI}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="20" width="158" height="20" uuid="2d8a791e-bdb2-4a8c-9be6-f4f751a388f5"/>
				<textFieldExpression><![CDATA["Nombre completo: " +  $F{NOMBRE}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="305" y="0" width="144" height="20" uuid="76d2ff84-8340-4f1c-b1df-bf65a44429c4"/>
