	<detail>
		<band height="204" splitType="Stretch">
			<textField>
				<reportElement x="0" y="5" width="505" height="128" uuid="e05cdec4-0390-4e40-a222-38e2f710d651"/>
				<textFieldExpression><![CDATA[$F{NOMBRE} + " con DNI/NIE " + $F{DNI} +" efectuó un pago de ***" + $F{IMPORTE} +"euros*** , (" + $F{METODO} +") con fecha de " +
new java.text.SimpleDateFormat("EEEEE dd MMMMM yyyy", new java.util.Locale("es","ES")).format($F{FECHA})+ "en concepto de: "+ $F{CONCEPTO} +"."]]></textFieldExpression>
			</textField>
		</band>
	</detail>
