	<parameter name="P_DNI" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="P_LOGO" class="java.io.InputStream" isForPrompting="false">
		<defaultValueExpression><![CDATA[new java.io.FileInputStream("C:/Githubsource/resources/img/Logo_FitManage.png")]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select c.dni as dni, c.nombre ||' ' || c.apellidos as nom,c.email as email,c.telefono as tlfn, a.nombre as nombract, r.fecha_clase as impart,r.fecha_reserva as reser,case when r.estado_activa = 1 then 'Activa' ELSE 'Cancelada' END as estado
from actividad a join actividad_dia d on a.id_actividad=d.id_actividad
join reserva r on d.id_act_dia = r.id_act_dia
join cliente c on r.id_cliente = c.id_cliente
where c.dni like $P{P_DNI}]]>
	</queryString>
	<field name="DNI" class="java.lang.String"/>
	<field name="NOM" class="java.lang.String"/>
	<field name="EMAIL" class="java.lang.String"/>
	<field name="TLFN" class="java.lang.String"/>
	<field name="NOMBRACT" class="java.lang.String"/>
	<field name="IMPART" class="java.sql.Timestamp"/>
	<field name="RESER" class="java.sql.Timestamp"/>
	<field name="ESTADO" class="java.lang.String"/>
